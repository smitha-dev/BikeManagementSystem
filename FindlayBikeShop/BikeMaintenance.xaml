<Window
    x:Class="FindlayBikeShop.MaintenanceHistory"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FindlayBikeShop"
    mc:Ignorable="d"
    Title="Maintenance Record"
    Height="560"
    Width="760"
    MinHeight="520"
    MinWidth="700"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="University of Findlay Bike Rentals"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource FindlayOrangeBrush}"/>
            <TextBlock Text="Maintenance Record"
                       FontSize="14"
                       Foreground="{StaticResource MutedTextBrush}"/>
        </StackPanel>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Photo card -->
            <Border Grid.Column="0"
                    Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Damage Photo"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <Border Height="220"
                            Background="#FAFAFA"
                            BorderBrush="{StaticResource FindlayGrayBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <TextBlock Text="No photo uploaded"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <Image x:Name="DamagePhoto"
                                   Stretch="Uniform"/>
                        </Grid>
                    </Border>

                    <Button Content="Upload Photo"
                            Width="120"
                            Margin="0,12,0,0"
                            Click="UploadPhoto_Click"/>
                </StackPanel>
            </Border>

            <!-- Details card -->
            <Border Grid.Column="2"
                    Style="{StaticResource SectionCard}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <TextBlock Text="Description of Damage"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <TextBox x:Name="NoteTextBox"
                                 Height="90"
                                 Padding="8"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,14"
                                 BorderBrush="{StaticResource FindlayGrayBrush}"/>

                        <TextBlock Text="Part Needed"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <TextBox x:Name="PartNeededBox"
                                 Height="34"
                                 Padding="8,6"
                                 Margin="0,0,0,14"
                                 BorderBrush="{StaticResource FindlayGrayBrush}"/>

                        <TextBlock Text="Cost to Repair"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <TextBox x:Name="CostTextBox"
                                 Width="140"
                                 Height="34"
                                 HorizontalAlignment="Left"
                                 Padding="8,6"
                                 BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Save"
                    Width="90"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="SaveButton_Click"/>

            <Button Content="Mark as Fixed"
                    Width="130"
                    Style="{StaticResource PrimaryActionButton}"
                    Click="FixedButton_Click"/>
        </StackPanel>
    </Grid>
</Window>