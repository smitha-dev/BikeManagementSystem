<Window
    x:Class="FindlayBikeShop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FindlayBikeShop"
    mc:Ignorable="d"
    Title="Findlay Bike Management System [Home]"
    Height="510"
    Width="800"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <!-- ========================= -->
        <!-- GRID LAYOUT               -->
        <!-- ========================= -->

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========================= -->
        <!-- NAVIGATION BUTTONS        -->
        <!-- ========================= -->

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="Maintenance" Width="100" Height="30" Grid.Column="0" Click="Home_Click"/>
            <Button Content="Inventory" Width="100" Height="30" Grid.Column="1" Click="Inventory_Click"/>
            <Button Content="Backup DB" Width="100" Height="30" Grid.Column="2" Click="Backup_Click"/>
            <Button Content="Restore DB" Width="100" Height="30" Grid.Column="3" Click="Restore_Click"/>
        </Grid>
        <!-- ========================= -->
        <!-- BIKES NEEDING REPAIR      -->
        <!-- ========================= -->
        <Label
            Content="Bikes that need repair"
            Grid.Row="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="0,5,0,0"/>

        <!-- ListBox to display -->
        <ListBox x:Name="BikeNeedToRepair"
                 Grid.Row="1"
                 Grid.ColumnSpan="2"
                 Margin="0,31,0,0"
                 d:ItemsSource="{d:SampleData ItemCount=5}" SelectionChanged="BikeNeedToRepair_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock TextWrapping="Wrap">
                        <Run Text="Bike ID: "/>
                        <Run Text="{Binding BikeID, StringFormat={}{0:D3}}"/>
                        <Run Text="   Notes: "/>
                        <Run Text="{Binding Notes}"/>
                        <Run Text="   Last Updated: "/>
                        <Run Text="{Binding LastUpdated}"/>
                    </TextBlock>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>


        <!-- ========================= -->
        <!-- AVAILABLE BIKES           -->
        <!-- ========================= -->
        <Label
            Content="Available bikes"
            Grid.Row="2"
            Grid.Column="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="0,5,0,0"/>

        <!-- ListBox to display -->
        <ListBox x:Name="AvailableBikeList"
                 Grid.Row="2"
                 Grid.Column="0"
                 Margin="0,30,15,0"
                 d:ItemsSource="{d:SampleData ItemCount=5}" SelectionChanged="AvailableBikeList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock TextWrapping="Wrap">
                        <Run Text="Bike ID: "/>
                        <Run Text="{Binding BikeID, StringFormat={}{0:D3}}"/>
                        <Run Text="   Brand: "/>
                        <Run Text="{Binding Brand}"/>
                        <Run Text="   Size: "/>
                        <Run Text="{Binding Size}"/>
                        <Run Text="   Color: "/>
                        <Run Text="{Binding Color}"/>
                    </TextBlock>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>


        <!-- ========================= -->
        <!-- UNAVAILABLE / RENTED BIKES -->
        <!-- ========================= -->

        <Label
            Content="Unavailable bikes"
            Grid.Row="2"
            Grid.Column="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="15,5,0,0"/>

        <!-- ListBox to display -->
        <ListBox x:Name="RentedBikeList"
                 Grid.Row="2"
                 Grid.Column="1"
                 Margin="15,30,0,0"
                 d:ItemsSource="{d:SampleData ItemCount=5}" SelectionChanged="RentedBikeList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock TextWrapping="Wrap">
                        <Run Text="Bike ID: "/>
                        <Run Text="{Binding BikeID, StringFormat={}{0:D3}}"/>
                        <Run Text="   Brand: "/>
                        <Run Text="{Binding Brand}"/>
                        <Run Text="   Size: "/>
                        <Run Text="{Binding Size}"/>
                        <Run Text="   Color: "/>
                        <Run Text="{Binding Color}"/>
                    </TextBlock>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
