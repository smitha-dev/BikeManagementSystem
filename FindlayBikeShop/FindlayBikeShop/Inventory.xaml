<Window
    x:Class="FindlayBikeShop.Inventory"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FindlayBikeShop"
    mc:Ignorable="d"
    Title="Findlay Bike Management System [Inventory]"
    Height="510"
    Width="800"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:StatusToButtonContentConverter x:Key="StatusToButtonContentConverter"/>
        <local:StatusToIsEnabledConverter x:Key="StatusToIsEnabledConverter"/>
    </Window.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button
            Content="Maintenance"
            Width="100"
            Height="30"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="Home_Click"/>

        <Button
            Content="Inventory"
            Width="100"
            Height="30"
            Margin="130,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="Inventory_Click"/>

        <ListView
            x:Name="BikesListView"
            Grid.Row="1"
            Margin="0,8,0,0"
            SelectionChanged="BikesListView_SelectionChanged"
            d:ItemsSource="{d:SampleData ItemCount=3}">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Padding="8"
                        Margin="6"
                        BorderBrush="LightGray"
                        BorderThickness="1"
                        CornerRadius="4">

                        <DockPanel>

                            <Image
                                Width="140"
                                Height="100"
                                Margin="0,0,12,0"
                                Stretch="UniformToFill"
                                Source="{Binding PhotoImage}"
                                d:Source="https://www.prioritybicycles.com/cdn/shop/files/600_hero_May2024_1of1.jpg"/>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock
                                    FontWeight="Bold"
                                    Text="{Binding BikeID, StringFormat='Bike ID: {0}'}"/>

                                <TextBlock
                                    Text="{Binding Brand, StringFormat='Brand: {0}'}"/>

                                <TextBlock
                                    Text="{Binding Size, StringFormat='Size: {0}'}"/>

                                <TextBlock
                                    Text="{Binding Color, StringFormat='Color: {0}'}"/>

                                <TextBlock
                                    Text="{Binding Status, StringFormat='Status: {0}'}"/>

                                <Button
                                    Content="{Binding Status, Converter={StaticResource StatusToButtonContentConverter}}"
                                    IsEnabled="{Binding Status, Converter={StaticResource StatusToIsEnabledConverter}}"
                                    Click="RentReturnButton_Click"
                                    Tag="{Binding}"
                                    Width="80"
                                    Margin="0,8,0,0"/>
                            </StackPanel>

                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ComboBox
            Name="StatusFilterComboBox"
            HorizontalAlignment="Left"
            Margin="640,0,0,0"
            VerticalAlignment="Center"
            Width="120"
            SelectedIndex="0"
            SelectionChanged="StatusFilterComboBox_SelectionChanged">

            <ComboBoxItem Content="All"/>
            <ComboBoxItem Content="Available"/>
            <ComboBoxItem Content="Rented"/>
            <ComboBoxItem Content="Maintenance"/>
            <ComboBoxItem Content="Retired"/>

        </ComboBox>

        <Button
            Content="Add Bike"
            Width="100"
            Height="30"
            Margin="0,10,0,0"
            Grid.Row="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Click="AddBike_Click"/>

    </Grid>
</Window>