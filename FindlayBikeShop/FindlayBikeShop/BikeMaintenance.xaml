<Window
    x:Class="FindlayBikeShop.MaintenanceHistory"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FindlayBikeShop"
    mc:Ignorable="d"
    Title="Maintenance Record"
    Height="400"
    Width="600"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Border
            BorderBrush="LightGray"
            BorderThickness="1"
            Padding="10"
            Margin="0,0,10,0">

            <StackPanel>

                <Image
                    x:Name="DamagePhoto"
                    Height="200"
                    Stretch="Uniform"/>

                <Button
                    Content="Upload Photo"
                    Width="120"
                    Margin="0,10,0,0"
                    Click="UploadPhoto_Click"/>

            </StackPanel>
        </Border>

        <StackPanel Grid.Column="1">

            <TextBlock
                Text="Description of damage:"
                FontWeight="Bold"
                Margin="0,0,0,5"/>

            <TextBox
                x:Name="NoteTextBox"
                Height="40"
                TextWrapping="Wrap"
                AcceptsReturn="True"
                Width="300"
                HorizontalAlignment="Left"
                />

            <TextBlock
                Text="Part needed:"
                FontWeight="Bold"
                Margin="0,15,0,5"
                HorizontalAlignment="Left"/>

            <TextBox
                x:Name="PartNeededBox"
                Width="300"
                HorizontalAlignment="Left"/>

            <TextBlock
                Text="Cost to repair:"
                FontWeight="Bold"
                Margin="0,15,0,5"
                HorizontalAlignment="Left"/>

            <TextBox
                x:Name="CostTextBox"
                Width="120"
                HorizontalAlignment="Left"/>


        </StackPanel>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Left column for Delete -->
                    <ColumnDefinition Width="*"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Right column for Save/Fixed -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Delete button on the left -->
                <Button
            Content="Delete"
            Width="100"
            Height="30"
            Background="Red"
            Foreground="White"
            Click="DeleteButton_Click"
            Grid.Column="0"/>

                <!-- Save button on the right -->
                <Button
            Content="Save"
            Width="100"
            Height="30"
            Margin="0,0,10,0"
            Click="SaveButton_Click"
            Grid.Column="2"/>

                <!-- Mark as Fixed button on the right -->
                <Button
            Content="Mark as fixed"
            Width="140"
            Height="30"
            Click="FixedButton_Click"
            Grid.Column="3"/>
            </Grid>
        </StackPanel>

    </Grid>
</Window>