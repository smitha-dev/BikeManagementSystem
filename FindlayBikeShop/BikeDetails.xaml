<!--
Window: BikeDetails
Purpose: Displays detailed information about a specific bike.
-->

<Window
    x:Class="FindlayBikeShop.BikeDetails"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FindlayBikeShop"
    mc:Ignorable="d"
    Title="Bike Details"
    Height="510"
    Width="800"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <!-- ========================= -->
        <!-- GRID LAYOUT               -->
        <!-- ========================= -->

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========================= -->
        <!-- NAVIGATION BUTTONS        -->
        <!-- ========================= -->

        <Button
            Content="Home"
            Width="100"
            Height="30"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="Home_Click"/>

        <Button
            Content="Inventory"
            Width="100"
            Height="30"
            Margin="130,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="Inventory_Click"/>


        <!-- BIKE IMAGE -->
        <Border
            Grid.Row="1"
            Grid.Column="0"
            BorderBrush="LightGray"
            BorderThickness="1"
            Padding="10"
            Margin="0,10,10,10">

            <Image Stretch="Uniform"/>
        </Border>


        <!-- BIKE DETAILS -->
        <StackPanel
            Grid.Row="1"
            Grid.Column="1"
            Margin="10">

            <TextBlock
                Text="Bike Details"
                FontWeight="Bold"
                FontSize="14"
                Margin="0,0,0,10"/>

            <!--
            TODO: Populate fields from selected Bike object
            -->

            <TextBlock Text="Bike ID:"/>
            <TextBlock Text="Brand:"/>
            <TextBlock Text="Size:"/>
            <TextBlock Text="Seat Height:"/>
            <TextBlock Text="Color:"/>
            <TextBlock Text="Current Status:"/>

            <Button
                Content="Upload Photo"
                Width="120"
                Margin="0,10,250,0"/>

        </StackPanel>


        <!-- MAINTENANCE HISTORY -->
        <GroupBox
            Header="Maintenance History"
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,0,10,5">

            <ListBox d:ItemsSource="{d:SampleData ItemCount=5}" SelectionChanged="ListBox_SelectionChanged"/>

            <!--
            TODO: Display maintenance records for this bike
            -->

        </GroupBox>


        <!-- RENTAL HISTORY -->
        <GroupBox
            Header="Rental History"
            Grid.Row="2"
            Grid.Column="1"
            Margin="0,0,0,5">

            <ListBox d:ItemsSource="{d:SampleData ItemCount=5}" SelectionChanged="ListBox_SelectionChanged_1"/>

            <!--
            TODO: Show past rentals for this bike
            -->

        </GroupBox>


        <!-- ACTION BUTTONS -->
        <Button
            Content="Flag for Maintenance"
            Grid.Row="3"
            Grid.Column="0"
            Width="150"
            HorizontalAlignment="Center" Click="Button_Click"/>

        <Button
            Content="Edit History"
            Grid.Row="3"
            Grid.Column="1"
            Width="120"
            HorizontalAlignment="Center"/>

    </Grid>

</Window>