<!-- ========================== -->
<!-- Bike details window -->
<!-- ========================== -->
<Window
    x:Class="FindlayBikeShop.BikeDetails"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FindlayBikeShop"
    mc:Ignorable="d"
    Title="Bike Details"
    Height="675"
    Width="1100"
    MinHeight="675"
    MinWidth="600"
    WindowStartupLocation="CenterScreen">

    <!-- ========================== -->
    <!-- Main page layout -->
    <!-- ========================== -->
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========================== -->
        <!-- Header -->
        <!-- ========================== -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="University of Findlay Bike Rentals"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{StaticResource FindlayOrangeBrush}"/>
                <TextBlock Text="Bike Details"
                   FontSize="14"
                   Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center">
                <Button Content="Inventory"
                Margin="0,0,10,0"
                Style="{StaticResource SecondaryButton}"
                Click="Inventory_Click"/>
                <Button Content="Maintenance"
                Style="{StaticResource SecondaryButton}"
                Click="Home_Click"/>
            </StackPanel>
        </Grid>

        <!-- ========================== -->
        <!-- Bike summary section -->
        <!-- ========================== -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Bike image card -->
            <Border
                Grid.Column="0"
                Style="{StaticResource SectionCard}">

                <Grid>
                    <Image
                        x:Name="BikeImage"
                        Stretch="Uniform"
                        Source="{Binding PhotoImage}"/>
                </Grid>
            </Border>

            <!-- Bike details card -->
            <Border
                Grid.Column="2"
                Style="{StaticResource SectionCard}">

                <StackPanel>
                    <TextBlock
                        Text="Bike Details"
                        FontSize="16"
                        FontWeight="Bold"
                        Margin="0,0,0,12"/>

                    <TextBlock Margin="0,0,0,4" Text="{Binding BikeID, StringFormat=Bike ID: {0}}"/>
                    <TextBlock Margin="0,0,0,4" Text="{Binding Brand, StringFormat=Brand: {0}}"/>
                    <TextBlock Margin="0,0,0,4" Text="{Binding Size, StringFormat=Size: {0}}"/>
                    <TextBlock Margin="0,0,0,4" Text="{Binding SeatHeight, StringFormat=Seat Height: {0} inches}"/>
                    <TextBlock Margin="0,0,0,4" Text="{Binding Color, StringFormat=Color: {0}}"/>
                    <TextBlock Margin="0,0,0,4" Text="{Binding Status, StringFormat=Current Status: {0}}"/>
                    <TextBlock Margin="0,0,0,12" Text="{Binding LastUpdated, StringFormat=Last Updated: {0}}"/>

                    <!-- Details actions -->
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Content="Upload Photo"
                            Width="120"
                            Margin="0,0,10,0"
                            Click="UploadPhoto_Click"/>

                        <Button
                            Content="Edit Details"
                            Width="120"
                            Click="EditDetails_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ========================== -->
        <!-- History sections -->
        <!-- ========================== -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Maintenance history -->
            <Border
                Grid.Column="0"
                Style="{StaticResource SectionCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Maintenance History"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Margin="0,0,0,8"/>

                    
                    <DataGrid
                        x:Name="MaintenanceHistoryGrid"
                        Grid.Row="1"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        SelectionChanged="MaintenanceHistoryGrid_SelectionChanged"
                        ScrollViewer.VerticalScrollBarVisibility="Visible"
                        ScrollViewer.HorizontalScrollBarVisibility="Visible">

                        <DataGrid.Columns>
<!--                            <DataGridTextColumn Header="Maintenance ID" Binding="{Binding MaintenanceID}" Width="100"/>-->
<!--                            <DataGridTextColumn Header="Bike ID" Binding="{Binding BikeID}" Width="80"/> -->
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="200"/>
                            <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="80"/>
                            <DataGridTextColumn Header="Date Flagged" Binding="{Binding DateFlagged}" Width="120"/>
                            <DataGridTextColumn Header="Date Fixed" Binding="{Binding DateFixed}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Rental history -->
            <Border
                Grid.Column="2"
                Style="{StaticResource SectionCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Rental History"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Margin="0,0,0,8"/>

                    <DataGrid
                        x:Name="RentalHistoryGrid"
                        Grid.Row="1"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        ScrollViewer.VerticalScrollBarVisibility="Visible"
                        ScrollViewer.HorizontalScrollBarVisibility="Visible">

                        <DataGrid.Columns>
                           <!-- <DataGridTextColumn Header="Rental ID" Binding="{Binding RentalID}" Width="60"/>-->
                            <DataGridTextColumn Header="Student" Binding="{Binding StudentID}" Width="80"/>
                            <DataGridTextColumn Header="Semester" Binding="{Binding SemesterRented}" Width="80"/>
                            <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="60"/>
                            <DataGridTextColumn Header="Checkout" Binding="{Binding CheckoutDate}" Width="80"/>
                            <DataGridTextColumn Header="Due" Binding="{Binding DueDate}" Width="80"/>
                            <DataGridTextColumn Header="Returned" Binding="{Binding ReturnDate}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ========================== -->
        <!-- Footer actions -->
        <!-- ========================== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left-side actions -->
            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                HorizontalAlignment="Left">

                <Button
                    x:Name="FlagMaintenanceButton"
                    Content="Flag for Maintenance"
                    Width="150"
                    Click="Maintenance_Click"/>

                <Button
                    x:Name="OpenMaintenanceButton"
                    Content="Open Maintenance"
                    Width="150"
                    Margin="10,0,0,0"
                    Click="OpenMaintenance_Click"
                    Visibility="Collapsed"/>
            </StackPanel>

            <!-- Right-side actions -->
            <Button
                Grid.Column="1"
                Content="Edit History"
                Width="120"
                Click="EditHistory_Click"/>

            <Button
                Grid.Column="3"
                Content="Rent Bike"
                Width="120"
                Click="RentBike_Click"/>
        </Grid>
    </Grid>
</Window>