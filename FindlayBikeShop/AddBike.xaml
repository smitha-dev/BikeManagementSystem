<!--
Window: BikeDetails
Purpose: Displays detailed information about a specific bike.
-->

<Window
    x:Class="FindlayBikeShop.AddBike"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FindlayBikeShop"
    mc:Ignorable="d"
    Title="Bike Details"
    Height="510"
    Width="800">

    <Grid Margin="10">

        <!-- ========================= -->
        <!-- GRID LAYOUT               -->
        <!-- ========================= -->

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- BIKE IMAGE -->
        <Border
            Grid.Row="1"
            Grid.Column="0"
            BorderBrush="LightGray"
            BorderThickness="1"
            Padding="10"
            Margin="0,10,10,10">

            <Image Stretch="Uniform"/>
        </Border>


        <!-- BIKE DETAILS -->
        <StackPanel
            Grid.Row="1"
            Grid.Column="1"
            Margin="10">

            <TextBlock
                Text="Bike Details"
                FontWeight="Bold"
                FontSize="14"
                Margin="0,0,0,10"/>

            <!--
            TODO: Populate fields from selected Bike object
            -->

            <TextBlock Text="Bike ID:"/>
            <TextBlock Text="Brand:"/>
            <TextBlock Text="Size:"/>
            <TextBlock Text="Seat Height:"/>
            <TextBlock Text="Color:"/>
            <TextBlock Text="Current Status:"/>

            <Button
                Content="Upload Photo"
                Width="120"
                Margin="0,10,250,0"/>

        </StackPanel>

    </Grid>

</Window>