<Window
    x:Class="FindlayBikeShop.AddBike"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add New Bike"
    Height="500"
    Width="480"
    MinHeight="550"
    MinWidth="460"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="University of Findlay Bike Rentals"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource FindlayOrangeBrush}"/>
            <TextBlock Text="Bike Details"
                       x:Name="BikeHeader"
                       FontSize="14"
                       Foreground="{StaticResource MutedTextBrush}"/>
        </StackPanel>

        <!-- Form card -->
        <Border Grid.Row="1"
                Style="{StaticResource SectionCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Brand"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="BrandBox"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <TextBlock Text="Size"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="SizeBox"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="S"/>
                        <ComboBoxItem Content="M"/>
                        <ComboBoxItem Content="L"/>
                    </ComboBox>

                    <TextBlock Text="Max Height (inches)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="MaxHeightBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Minimum Height (inches)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="MinHeightBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Color"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    
                    <TextBox x:Name="ColorBox"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <TextBlock Text="Status"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="StatusBox">
                        <ComboBoxItem Content="Available"/>
                        <ComboBoxItem Content="Rented"/>
                        <ComboBoxItem Content="Maintenance"/>
                        <ComboBoxItem Content="Retired"/>
                    </ComboBox>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Cancel"
                    Width="90"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click"/>

            <Button Content="Save Bike"
                    Width="100"
                    Style="{StaticResource PrimaryActionButton}"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>