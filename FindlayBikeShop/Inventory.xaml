<Window
    x:Class="FindlayBikeShop.Inventory"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FindlayBikeShop"
    mc:Ignorable="d"
    Title="Findlay Bike Management System [Inventory]"
    Height="675"
    Width="1100"
    MinHeight="675"
    MinWidth="600"
    WindowStartupLocation="CenterScreen">

    <!-- ========================== -->
    <!-- Window resources -->
    <!-- ========================== -->
    <Window.Resources>
        <local:StatusToButtonContentConverter x:Key="StatusToButtonContentConverter"/>
        <local:StatusToIsEnabledConverter x:Key="StatusToIsEnabledConverter"/>
    </Window.Resources>

    <!-- ========================== -->
    <!-- Main page layout -->
    <!-- ========================== -->
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title row -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="University of Findlay Bike Rentals"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource FindlayOrangeBrush}"/>
                    <TextBlock Text="Inventory Dashboard"
                       FontSize="14"
                       Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <Button Content="Inventory"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="Inventory_Click"/>
                    <Button Content="Maintenance"
                    Style="{StaticResource SecondaryButton}"
                    Click="Home_Click"/>
                </StackPanel>
            </Grid>

            <!-- Filter row -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <TextBlock Text="Status Filter"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource MutedTextBrush}"/>

                    <ComboBox x:Name="StatusFilterComboBox"
                      Width="150"
                      SelectedIndex="0"
                      SelectionChanged="StatusFilterComboBox_SelectionChanged">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Available"/>
                        <ComboBoxItem Content="Rented"/>
                        <ComboBoxItem Content="Maintenance"/>
                        <ComboBoxItem Content="Retired"/>
                    </ComboBox>
                </StackPanel>

                <Button Grid.Column="1"
                Content="Backup"
                Style="{StaticResource SecondaryButton}"
                Click="Backup_Click"/>
            </Grid>
        </Grid>
        <!-- ========================== -->
        <!-- Inventory listing section -->
        <!-- ========================== -->
        <Border
            Grid.Row="1"
            Style="{StaticResource SectionCard}"
            Margin="0,0,0,12">

            <ListView
    x:Name="BikesListView"
    BorderThickness="0"
    Background="Transparent"
    MouseDoubleClick="BikesListView_MouseDoubleClick"
    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
    d:ItemsSource="{d:SampleData ItemCount=6}">

                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Width" Value="320"/>
                        <Setter Property="Margin" Value="6"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border
                Padding="10"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="6">

                            <StackPanel>
                                <Image
                        Height="150"
                        Margin="0,0,0,10"
                        Stretch="UniformToFill"
                        Source="{Binding PhotoImage}"
                        d:Source="https://www.prioritybicycles.com/cdn/shop/files/600_hero_May2024_1of1.jpg"/>

                                <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Margin="0,0,0,4"
                        Text="{Binding BikeID, StringFormat='Bike ID: {0}'}"/>

                                <TextBlock Margin="0,0,0,2" Text="{Binding Brand, StringFormat='Brand: {0}'}"/>
                                <TextBlock Margin="0,0,0,2" Text="{Binding Size, StringFormat='Size: {0}'}"/>
                                <TextBlock Margin="0,0,0,2" Text="{Binding Color, StringFormat='Color: {0}'}"/>
                                <TextBlock Margin="0,0,0,2" Text="{Binding Status, StringFormat='Status: {0}'}"/>

                                <Button
                        Width="80"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        Content="{Binding Status, Converter={StaticResource StatusToButtonContentConverter}}"
                        IsEnabled="{Binding Status, Converter={StaticResource StatusToIsEnabledConverter}}"
                        Click="RentReturnButton_Click"
                        Tag="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- ========================== -->
        <!-- Footer actions -->
        <!-- ========================== -->
        <Grid Grid.Row="2">
            <Button
                Content="Add Bike"
                HorizontalAlignment="Right"
                Click="AddBike_Click"/>
        </Grid>
    </Grid>
</Window>