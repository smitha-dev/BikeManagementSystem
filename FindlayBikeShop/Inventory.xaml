<!--
Window: Inventory
Purpose: Displays all bikes in the system inventory.

Future Work:
- Bind bikes to Bike model
- Implement rental logic
-->

<Window
    x:Class="FindlayBikeShop.Inventory"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FindlayBikeShop"
    mc:Ignorable="d"
    Title="Findlay Bike Management System [Inventory]"
    Height="510"
    Width="800"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <!-- ========================= -->
        <!-- GRID LAYOUT               -->
        <!-- ========================= -->

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========================= -->
        <!-- NAVIGATION BUTTONS        -->
        <!-- ========================= -->

        <Button
            Content="Home"
            Width="100"
            Height="30"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="Home_Click"/>

        <Button
            Content="Inventory"
            Width="100"
            Height="30"
            Margin="130,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="Inventory_Click"/>


        <!-- ========================= -->
        <!-- INVENTORY LIST            -->
        <!-- ========================= -->

        <ListView
            x:Name="BikesListView"
            Grid.Row="1"
            Margin="0,8,0,0"
            d:ItemsSource="{d:SampleData ItemCount=3}">

            <ListView.ItemTemplate>
                <DataTemplate>

                    <Border
                        Padding="8"
                        Margin="6"
                        BorderBrush="LightGray"
                        BorderThickness="1"
                        CornerRadius="4">

                        <DockPanel>

                            <!-- BIKE PHOTO -->
                            <Image
                                Width="140"
                                Height="100"
                                Margin="0,0,12,0"
                                Stretch="UniformToFill"
                                Source="{Binding Photo}"
                                d:Source="https://www.prioritybicycles.com/cdn/shop/files/600_hero_May2024_1of1.jpg"/>
                            <!-- placeholder image -->


                            <!-- BIKE DETAILS -->
                            <StackPanel VerticalAlignment="Center">

                                <!--
                                TODO: Bind fields to Bike information
                                -->

                                <TextBlock
                                    FontWeight="Bold"
                                    Text="{Binding BikeID, StringFormat='Bike ID: {0}'}"
                                    d:Text="Bike ID: 101"/>

                                <TextBlock
                                    Text="{Binding Brand, StringFormat='Brand: {0}'}"
                                    d:Text="Size: Medium"/>

                                <TextBlock
                                    Text="{Binding Size, StringFormat='Size: {0}'}"
                                    d:Text="Seat Height: 30in"/>

                                <TextBlock
                                    Text="{Binding Color, StringFormat='Color: {0}'}"
                                    d:Text="Color: Black"/>

                                <TextBlock
                                    Text="{Binding Status, StringFormat='Status: {0}'}"
                                    d:Text="Status: Available"/>


                                <!-- RENT BUTTON -->
                                <Button
                                    Content="Rent"
                                    Width="80"
                                    Margin="0,8,0,0"
                                    IsEnabled="False"/>

                                <!--
                                TODO: Implement rental logic
                                Notes: Should update bike Status to "Rented"
                                -->

                            </StackPanel>

                        </DockPanel>

                    </Border>

                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

        <Button
            Content="Add Bike"
            Width="100"
            Height="30"
            Margin="0,10,0,0"
            Grid.Row="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Click="AddBike_Click"/>

    </Grid>

</Window>