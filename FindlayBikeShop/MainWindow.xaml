<Window
    x:Class="FindlayBikeShop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FindlayBikeShop"
    mc:Ignorable="d"
    Title="Findlay Bike Management System [Maintenance]"
    Height="675"
    Width="1100"
    MinHeight="675"
    MinWidth="600"
    WindowStartupLocation="CenterScreen">

    <!-- ========================== -->
    <!-- Main page layout -->
    <!-- ========================== -->
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========================== -->
        <!-- Header -->
        <!-- ========================== -->

        <Grid Grid.Row="0" Margin="0,0,0,12">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="0">
        <TextBlock Text="University of Findlay Bike Rentals"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{StaticResource FindlayOrangeBrush}"/>
        <TextBlock Text="Maintenance Dashboard"
                   FontSize="14"
                   Foreground="{StaticResource MutedTextBrush}"/>
    </StackPanel>

    <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center">
        <Button Content="Inventory"
                Margin="0,0,10,0"
                Style="{StaticResource SecondaryButton}"
                Click="Inventory_Click"/>
        <Button Content="Maintenance"
                Click="Home_Click"
                Style="{StaticResource SecondaryButton}"/>
    </StackPanel>
</Grid>

        <!-- ========================== -->
        <!-- Bikes needing repair section -->
        <!-- ========================== -->
        <Border
            Grid.Row="1"
            Style="{StaticResource SectionCard}"
            Margin="0,0,0,12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Label
                    Grid.Row="0"
                    Content="Bikes that need repair"/>

                <ListBox
                    x:Name="BikeNeedToRepair"
                    Grid.Row="1"
                    d:ItemsSource="{d:SampleData ItemCount=5}"
                    SelectionChanged="BikeNeedToRepair_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock TextWrapping="Wrap" Margin="4">
                                <Run Text="Bike ID: "/>
                                <Run Text="{Binding BikeID, StringFormat={}{0:D3}}"/>
                                <Run Text="   Notes: "/>
                                <Run Text="{Binding Notes}"/>
                                <Run Text="   Last Updated: "/>
                                <Run Text="{Binding LastUpdated}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ========================== -->
        <!-- Bottom bike status sections -->
        <!-- ========================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Available bikes section -->
            <Border
                Grid.Column="0"
                Style="{StaticResource SectionCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label
                        Grid.Row="0"
                        Content="Available bikes"/>

                    <ListBox
                        x:Name="AvailableBikeList"
                        Grid.Row="1"
                        d:ItemsSource="{d:SampleData ItemCount=5}"
                        SelectionChanged="AvailableBikeList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock TextWrapping="Wrap" Margin="4">
                                    <Run Text="Bike ID: "/>
                                    <Run Text="{Binding BikeID, StringFormat={}{0:D3}}"/>
                                    <Run Text="   Brand: "/>
                                    <Run Text="{Binding Brand}"/>
                                    <Run Text="   Size: "/>
                                    <Run Text="{Binding Size}"/>
                                    <Run Text="   Color: "/>
                                    <Run Text="{Binding Color}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Unavailable bikes section -->
            <Border
                Grid.Column="2"
                Style="{StaticResource SectionCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label
                        Grid.Row="0"
                        Content="Unavailable bikes"/>

                    <ListBox
                        x:Name="RentedBikeList"
                        Grid.Row="1"
                        d:ItemsSource="{d:SampleData ItemCount=5}"
                        SelectionChanged="RentedBikeList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock TextWrapping="Wrap" Margin="4">
                                    <Run Text="Bike ID: "/>
                                    <Run Text="{Binding BikeID, StringFormat={}{0:D3}}"/>
                                    <Run Text="   Brand: "/>
                                    <Run Text="{Binding Brand}"/>
                                    <Run Text="   Size: "/>
                                    <Run Text="{Binding Size}"/>
                                    <Run Text="   Color: "/>
                                    <Run Text="{Binding Color}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>