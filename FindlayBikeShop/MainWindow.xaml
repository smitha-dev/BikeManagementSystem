<!--
Window: MainWindow
Purpose: Dashboard for the Findlay Bike Management System

Displays:
- Bikes needing repair
- Available bikes
- Unavailable bikes

Future Work:
- Bind lists to Bike data model
- Filter bikes by Status
-->

<Window
    x:Class="FindlayBikeShop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FindlayBikeShop"
    mc:Ignorable="d"
    Title="Findlay Bike Management System [Home]"
    Height="510"
    Width="800">

    <Grid Margin="10">

        <!-- ========================= -->
        <!-- GRID LAYOUT               -->
        <!-- ========================= -->

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <!-- ========================= -->
        <!-- NAVIGATION BUTTONS        -->
        <!-- ========================= -->

        <Button
            Content="Home"
            Width="100"
            Height="30"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="Home_Click"/>

        <Button
            Content="Inventory"
            Width="100"
            Height="30"
            Margin="130,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="Inventory_Click"/>

        <Button
            Content="Open Maintenance"
            Width="100"
            Height="30"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="OpenMaintenance_Click" Grid.ColumnSpan="2" Margin="275,0,355,0"/>

        <!-- BIKES NEEDING REPAIR -->
        <Label
            Content="Bikes that need repair"
            Grid.Row="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="0,5,0,0"/>

        <ListBox
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="0,31,0,0"
            d:ItemsSource="{d:SampleData ItemCount=5}"/>

        <!--
        TODO: Bind this ListBox to bikes requiring repair
        Notes: Filter bikes where Status == "Maintenance"
        -->


        <!-- AVAILABLE BIKES -->
        <Label
            Content="Available bikes"
            Grid.Row="2"
            Grid.Column="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="0,5,0,0"/>

        <ListBox
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,30,15,0"
            d:ItemsSource="{d:SampleData ItemCount=5}"/>

        <!--
        TODO: Bind this list to bikes available for rental
        Notes: Filter bikes where Status == "Available"
        -->

        <!-- UNAVAILABLE BIKES -->
        <Label
            Content="Unavailable bikes"
            Grid.Row="2"
            Grid.Column="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="15,5,0,0"/>

        <ListBox
            Grid.Row="2"
            Grid.Column="1"
            Margin="15,30,0,0"
            d:ItemsSource="{d:SampleData ItemCount=5}"/>

        <!--
        TODO: Bind to bikes currently not rentable
        Notes: Status may include "Rented", "Maintenance", or "Lost"
        -->

    </Grid>

</Window>