<Window
    x:Class="FindlayBikeShop.EditRentalHistory"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edit Rental History"
    Height="500"
    Width="400"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Text="Edit Rental Record"
            FontSize="18"
            FontWeight="Bold"
            Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,10,0,10">

                <TextBlock Text="Student ID"/>
                <TextBox x:Name="StudentIDBox" Margin="0,0,0,10"/>

                <TextBlock Text="Semester Rented"/>
                <TextBox x:Name="SemesterBox" Margin="0,0,0,10"/>

                <TextBlock Text="Year"/>
                <TextBox x:Name="YearBox" Margin="0,0,0,10"/>

                <TextBlock Text="Checkout Date (mm-dd-yyyy)"/>
                <TextBox x:Name="CheckoutDateBox" Margin="0,0,0,10"/>

                <TextBlock Text="Due Date (mm-dd-yyyy)"/>
                <TextBox x:Name="DueDateBox" Margin="0,0,0,10"/>

                <TextBlock Text="Return Date (mm-dd-yyyy)"/>
                <TextBox x:Name="ReturnDateBox" Margin="0,0,0,10"/>

                <TextBlock Text="Check-in Date 1 (mm-dd-yyyy)"/>
                <TextBox x:Name="CheckinDate1Box" Margin="0,0,0,10"/>

                <TextBlock Text="Check-in Date 2 (mm-dd-yyyy)"/>
                <TextBox x:Name="CheckinDate2Box" Margin="0,0,0,10"/>

                <TextBlock Text="Check-in Date 3 (mm-dd-yyyy)"/>
                <TextBox x:Name="CheckinDate3Box" Margin="0,0,0,10"/>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Cancel"
                    Width="80"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>

            <Button Content="Save"
                    Width="80"
                    Click="Save_Click"/>
        </StackPanel>

    </Grid>
</Window>