<Window
    x:Class="FindlayBikeShop.EditRentalHistory"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edit Rental History"
    Height="650"
    Width="500"
    MinHeight="600"
    MinWidth="460"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="University of Findlay Bike Rentals"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource FindlayOrangeBrush}"/>
            <TextBlock Text="Rental Record"
                       FontSize="14"
                       Foreground="{StaticResource MutedTextBrush}"/>
        </StackPanel>

        <!-- Form card -->
        <Border Grid.Row="1"
                Style="{StaticResource SectionCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Student ID"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="StudentIDBox"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <TextBlock Text="Semester Rented"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="SemesterBox"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <TextBlock Text="Year"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="YearBox"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <TextBlock Text="Checkout Date (MM-DD-YYYY)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="CheckoutDateBox"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <TextBlock Text="Due Date (MM-DD-YYYY)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="DueDateBox"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <TextBlock Text="Return Date (MM-DD-YYYY)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="ReturnDateBox"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <TextBlock Text="Check-in Date 1 (MM-DD-YYYY)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="CheckinDate1Box"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <TextBlock Text="Check-in Date 2 (MM-DD-YYYY)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="CheckinDate2Box"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <TextBlock Text="Check-in Date 3 (MM-DD-YYYY)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="CheckinDate3Box"
                             Height="34"
                             Padding="8,6"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Cancel"
                    Width="90"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click"/>

            <Button Content="Save Changes"
                    Width="110"
                    Style="{StaticResource PrimaryActionButton}"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>