<Window
    x:Class="FindlayBikeShop.EditRentalHistory"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edit Rental History"
    Height="650"
    Width="500"
    MinHeight="600"
    MinWidth="460"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="University of Findlay Bike Rentals"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource FindlayOrangeBrush}"/>
            <TextBlock Text="Rental Record"
                       FontSize="14"
                       Foreground="{StaticResource MutedTextBrush}"/>
        </StackPanel>

        <!-- Form card -->
        <Border Grid.Row="1"
                Style="{StaticResource SectionCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Student ID"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="StudentIDBox"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <TextBlock Text="Semester Rented"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="SemesterBox"
                              Height="34"
                              Margin="0,0,0,12"
                              Padding="8,6"
                              BorderBrush="{StaticResource FindlayGrayBrush}">
                        <ComboBoxItem Content="Fall"/>
                        <ComboBoxItem Content="Spring"/>
                        <ComboBoxItem Content="Summer"/>
                    </ComboBox>

                    <TextBlock Text="Year"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="YearBox"
                             Height="34"
                             Padding="8,6"
                             Margin="0,0,0,12"
                             BorderBrush="{StaticResource FindlayGrayBrush}"/>

                    <!-- Dates in 2 columns -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- LEFT COLUMN -->

                        <!-- Checkout -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
               Text="Checkout Date"
               FontWeight="SemiBold"
               Margin="0,0,0,6"/>
                        <DatePicker x:Name="CheckoutDatePicker"
                Grid.Row="1" Grid.Column="0"
                Height="34"
                Margin="0,0,0,12"/>

                        <!-- Due Date -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
               Text="Due Date"
               FontWeight="SemiBold"
               Margin="0,0,0,6"/>
                        <DatePicker x:Name="DueDatePicker"
                Grid.Row="3" Grid.Column="0"
                Height="34"
                Margin="0,0,0,12"/>

                        <!-- Return -->
                        <TextBlock Grid.Row="4" Grid.Column="0"
               Text="Return Date"
               FontWeight="SemiBold"
               Margin="0,0,0,6"/>
                        <DatePicker x:Name="ReturnDatePicker"
                Grid.Row="5" Grid.Column="0"
                Height="34"/>


                        <!-- RIGHT COLUMN -->

                        <!-- Check-in 1 -->
                        <TextBlock Grid.Row="0" Grid.Column="2"
               Text="Check-in Date 1"
               FontWeight="SemiBold"
               Margin="0,0,0,6"/>
                        <DatePicker x:Name="CheckinDate1Picker"
                Grid.Row="1" Grid.Column="2"
                Height="34"
                Margin="0,0,0,12"/>

                        <!-- Check-in 2 -->
                        <TextBlock Grid.Row="2" Grid.Column="2"
               Text="Check-in Date 2"
               FontWeight="SemiBold"
               Margin="0,0,0,6"/>
                        <DatePicker x:Name="CheckinDate2Picker"
                Grid.Row="3" Grid.Column="2"
                Height="34"
                Margin="0,0,0,12"/>

                        <!-- Check-in 3 -->
                        <TextBlock Grid.Row="4" Grid.Column="2"
               Text="Check-in Date 3"
               FontWeight="SemiBold"
               Margin="0,0,0,6"/>
                        <DatePicker x:Name="CheckinDate3Picker"
                Grid.Row="5" Grid.Column="2"
                Height="34"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Delete"
                    Width="90"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="DeleteButton_Click"/>
            <Button Content="Cancel"
                    Width="90"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click"/>

            <Button Content="Save Changes"
                    Width="110"
                    Style="{StaticResource PrimaryActionButton}"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>